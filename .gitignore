# ─── Python ──────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.pyo
*.pyd

# ─── Virtual Environment ─────────────────────────────
venv/
.venv/
env/
.env/
ENV/

# ─── Distribution / Build ────────────────────────────
build/
dist/
*.spec
*.egg-info/
*.egg
*.manifest
*.whl

# ─── PyInstaller ─────────────────────────────────────
*.spec

# ─── IDE / Editor ────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.project
.settings/

# ─── OS Generated ───────────────────────────────────
Thumbs.db
ehthumbs.db
Desktop.ini
.DS_Store
.DS_Store?
._*

# ─── App Runtime Directories ────────────────────────
# Audio downloads (temporary)
downloads/*.mp3
downloads/*.wav
downloads/*.m4a
downloads/*.mp4
downloads/*.webm
downloads/*.opus
!downloads/.gitkeep

# Exported transcripts (user files)
exports/*.txt
exports/*.md
exports/*.srt
!exports/.gitkeep

# Whisper models (large binary files)
models/
!models/.gitkeep

# ─── FFmpeg Binary ──────────────────────────────────
ffmpeg/*.exe
ffmpeg/*.dll
!ffmpeg/.gitkeep

# ─── Logs & Temp ────────────────────────────────────
*.log
*.tmp
*.temp
*.bak
